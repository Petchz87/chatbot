# config.example.env

# --- Database Config ---
# (นี่คือ "ชื่อวิเศษ" ที่ Docker ใช้คุยกับ Windows หรือ Host ของคุณ)
DB_HOST=db
DB_PORT=5432
DB_NAME=admin_chatbot
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# --- Ollama Config ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_NAME=your_model_name_here

# --- Messenger Config ---
# 1. รหัสลับที่คุณตั้งเอง (ต้องตรงกับที่ใส่ในหน้า Webhook)
MESSENGER_VERIFY_TOKEN=your_verify_token_here

# 2. โทเค็นเพจ (Page Access Token)
# ไปเอามาจากหน้า Meta Developer > Messenger > Access Tokens > Generate Token
MESSENGER_PAGE_ACCESS_TOKEN=your_page_access_token_here

# --- Email / SMTP Config ---
ADMIN_ALERT_EMAIL=admin_receiver@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sender_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_USE_TLS=true
